# ==============================================================================
# Django
# ==============================================================================
SECRET_KEY=your-secret-key-here
DJANGO_SETTINGS_MODULE=config.settings.development

# ==============================================================================
# Banco de Dados (PostgreSQL)
# ==============================================================================
POSTGRES_DB=your_database_name
POSTGRES_USER=your_database_user
POSTGRES_PASSWORD=your_database_password
# Montar a URL com os valores acima
DATABASE_URL=postgresql://your_database_user:your_database_password@localhost:5432/your_database_name
# Em produção, trocar localhost pelo nome do serviço no Docker: @db:5432

# ==============================================================================
# Armazenamento de Objetos (S3)
# ==============================================================================
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=your_bucket_name
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION_NAME=us-east-1
#MINIO_PORT=9000
#MINIO_CONSOLE_PORT=9001

# ==============================================================================
# Produção (preencher apenas no servidor)
# ==============================================================================
# ALLOWED_HOSTS=your-domain.com
# CSRF_TRUSTED_ORIGINS=https://your-domain.com
